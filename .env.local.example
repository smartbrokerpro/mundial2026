# ── Fuente de datos (sin base de datos: se cachea en memoria en el server) ──
# espn (DEFAULT): API pública de ESPN, gratis, SIN key, Mundial 2026 en vivo.
# api-football / football-data.org: requieren su key (opcional).
DATA_SOURCE=espn

# Caché en memoria (segundos): cada cuánto se refresca desde el proveedor.
# Con esto el origen recibe ~1 request por intervalo sin importar el tráfico.
DATA_TTL_SECONDS=30

# Solo si DATA_SOURCE=api-football (https://dashboard.api-football.com/register):
API_FOOTBALL_KEY=

# Solo si DATA_SOURCE=football-data.org (https://www.football-data.org/client/register):
FOOTBALL_DATA_API_KEY=
